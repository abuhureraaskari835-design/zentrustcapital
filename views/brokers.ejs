<style>
  /* nav{
      margin-top: 90px;
    } */


  .container>p {
    color: var(--pages-text2);
    margin-top: 12px;
    max-width: 560px;
  }

  .badge-gold {
    margin-left: 8px;
  }

  .filter-bar {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 36px;
  }

  .filter-btn {
    padding: 8px 20px;
    border-radius: 50px;
    font-size: 0.84rem;
    font-weight: 600;
    background: var(--pages-bg3);
    border: 1px solid var(--pages-border);
    color: var(--pages-text2);
    transition: all var(--pages-transition);
    cursor: pointer;
  }

  .filter-btn.active,
  .filter-btn:hover {
    background: linear-gradient(135deg, var(--blue-to-teal12), var(--darkBlue-to-sage2));
    color: var(--btn-text);
    box-shadow: var(--shadow-btn-main);
  }

  .broker-row {
    background: var(--pages-card-bg);
    border: 1px solid var(--pages-border);
    border-radius: var(--pages-radius-lg);
    padding: 28px;
    margin-bottom: 16px;
    display: grid;
    grid-template-columns: 60px 1fr auto auto auto auto;
    align-items: center;
    gap: 20px;
    transition: all var(--pages-transition);
  }

  .broker-row:hover {
    border-color: var(--bk-border-hover);
    transform: translateY(-2px);
    box-shadow: var(--shadow-bk-hover);
  }

  .broker-logo {
    width: 56px;
    height: 56px;
    border-radius: 12px;
    background: var(--pages-bg4);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--pages-font-display);
    font-weight: 800;
    font-size: 1.1rem;
    color: var(--pages-gold);
  }

  .broker-info h3 {
    font-family: var(--pages-font-display);
    font-size: 1.1rem;
    margin-bottom: 4px;
  }

  .broker-info p {
    font-size: 0.84rem;
    color: var(--pages-text2);
  }

  .broker-stat {
    text-align: center;
  }

  .broker-stat strong {
    display: block;
    font-family: var(--pages-font-display);
    font-size: 1.05rem;
    font-weight: 700;
  }

  .broker-stat span {
    font-size: 0.76rem;
    color: var(--pages-text3);
  }

  .btn-secondary {
    padding: 9px 18px;
    font-size: 0.84rem;
    white-space: nowrap;
    justify-content: center;
  }

  .btn-primary {
    padding: 9px 18px;
    font-size: 0.84rem;
    white-space: nowrap;
  }

    .stars{
      display: flex;
    justify-items: flex-start;
      color: var(--pages-text2);

     }
     
  .full-filled-star {
    color: var(--pages-gold);
    /* border: 1px solid var(--pages-gold); */
  }

  .half-filled-star {
    color: var(--pages-text2);
    /* 1. Base right side color (empty grey) */
    position: relative;
    display: inline-block;
  }

  .half-filled-star::after {
    display: flex;
    /* 2. Creates a pseudo-element overlay */
    content: '★';
    /* content: '☆'; */
    /* 3. MUST duplicate the star string to provide text vector bounds */
    position: absolute;
    top: 0;
    left: 0;
    width: 50%;
    /* 4. Slices the overlay box precisely in half horizontally */
    height: 100%;

    /* 5. Your exact top-to-bottom transparency gradient mask */
    -webkit-mask-image: linear-gradient(to bottom, black, transparent);
    mask-image: linear-gradient(to right, var(--pages-gold), var(--pages-gold));

    /* 6. THE MAGIC: Snaps the mask edges tightly to the letter paths of your '★' */
    -webkit-mask-clip: text;

    /* 7. The filled overlay color (gold) */
    color: var(--pages-gold);

    z-index: 1;
    /* 8. Layers the gold half-star directly on top */
  }

  @media(max-width:900px) {
    .broker-row {
      grid-template-columns: 1fr;
    }
  }

  .compare-brokers {
    text-align: center;
    margin-top: 40px;
  }
</style>
</head>

