  <script>
    function filterBrokers(btn, tag) {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      document.querySelectorAll('.broker-row').forEach(row => {
        if (tag === 'all' || row.dataset.tags?.includes(tag)) {
          row.style.display = 'grid';
        } else {
          row.style.display = 'none';
        }
      });
    }
    let abc = `<%- include('partials/theme-home-btn') %>`;
    console.log('theme is', abc)



    // MY LOGIC ::::::::::::::::::::::::::::::::::::::::::
    let ratingStars = document.querySelectorAll('.rating-stars span');

    console.log(typeof `<%= editAddBroker.brokerRating %>`);
    for (let i = 0; i < Number(`<%= editAddBroker.brokerRating %>`); i++) {
      if (Number.isInteger(+`<%= editAddBroker.brokerRating %>`)) {
        console.log('the number is an integer', this.value);

        ratingStars[i].classList.add('full-filled-star');

      } else {

        ratingStars[i].classList.add('full-filled-star');
        console.log('the number is not an integer');

        if (Number(`<%= editAddBroker.brokerRating %>`) - i < 1) {
          ratingStars[i].classList.replace('full-filled-star', 'half-filled-star');
          console.log('Star is half filled. the number is not an integer');
        }

      }

    }
  </script>
