<%- include('partials/head') %>
<%- include('partials/style') %>
</head>

<body>

  <!-- ═══════════ PRELOADER -->
  <div id="preloader">
    <div class="pre-logo">ZEN TRUST CAPITAL</div>
    <div class="pre-sub">Global Forex Intelligence Platform</div>
    <div class="pre-track">
      <div class="pre-fill"></div>
    </div>
  </div>



  <!-- ═══════════ HEADER -->
  <%- include('partials/header') %>



  <!-- ═══════════ TICKER -->
  <div class="ticker-wrap">
    <div class="ticker-badge">
      <div class="live-dot"></div>
      LIVE
    </div>
    <div class="ticker-scroll">
      <div class="ticker-inner" id="tickerInner"></div>
    </div>
  </div>

  <!-- ═══════════ HERO -->
  <section class="hero" id="hero">
    <div class="hero-canvas"></div>
    <div class="hero-grid-lines"></div>
    <div class="hero-orb1"></div>
    <div class="hero-orb2"></div>
    <div class="hero-content">
      <div class="hero-label">
        <div class="ld"></div><span>Trusted by 50,000+ Traders Worldwide</span>
      </div>
      <h1>Master the<br><span class="hl">Forex Market</span><br>with Confidence</h1>
      <p class="hero-desc">ZEN TRUST CAPITAL connects elite traders with the world's finest brokers, cutting-edge market
        intelligence, and a community built for lasting success.</p>
      <div class="hero-btns">
        <a href="/open-account" class="btn-hero-main">Open Free Account <span class="btn-arrow">→</span></a>
        <a href="/brokers" class="btn-hero-out">Explore Brokers <span class="btn-arrow">→</span></a>
      </div>
      <div class="hero-kpis">
        <div class="kpi-pill"><span class="kpi-ico">⚡</span><span class="kpi-val">1:2000</span><span class="kpi-lbl">Max
            Leverage</span></div>
        <div class="kpi-pill"><span class="kpi-ico">💰</span><span class="kpi-val">$1</span><span class="kpi-lbl">Min
            Deposit</span></div>
        <div class="kpi-pill"><span class="kpi-ico">📊</span><span class="kpi-val">50+</span><span
            class="kpi-lbl">Pairs</span></div>
        <div class="kpi-pill"><span class="kpi-ico">🛡️</span><span class="kpi-val">FCA</span><span
            class="kpi-lbl">Regulated</span></div>
      </div>
    </div>
    <div class="hero-visual">
      <div class="main-chart-card" style="position:relative">
        <div class="cc-header">
          <div class="cc-pair">EUR / USD</div>
          <div class="cc-badge">▲ +0.38%</div>
        </div>
        <div class="cc-price" id="heroPrice">1.08472</div>
        <div class="cc-sub">Bid · Last updated just now</div>
        <div class="chart-svg-wrap">
          <svg viewBox="0 0 460 110" xmlns="http://www.w3.org/2000/svg"
            style="width:100%;height:110px;overflow:visible">
            <defs>
              <linearGradient id="cg1" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0%" stop-color="#0f3d6e" />
                <stop offset="100%" stop-color="#1e7ec8" />
              </linearGradient>
              <linearGradient id="ca1" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#1560a0" stop-opacity=".18" />
                <stop offset="100%" stop-color="#1560a0" stop-opacity="0" />
              </linearGradient>
            </defs>
            <path class="chart-area"
              d="M0,95 L26,88 L52,91 L78,78 L104,82 L130,68 L156,73 L182,60 L208,64 L234,52 L260,56 L286,42 L312,47 L338,33 L364,28 L390,18 L416,22 L442,12 L460,15 L460,110 L0,110 Z" />
            <path class="chart-path"
              d="M0,95 L26,88 L52,91 L78,78 L104,82 L130,68 L156,73 L182,60 L208,64 L234,52 L260,56 L286,42 L312,47 L338,33 L364,28 L390,18 L416,22 L442,12 L460,15" />
            <circle class="chart-dot" cx="460" cy="15" r="5" />
            <circle class="chart-dot-ring" cx="460" cy="15" r="9">
              <animate attributeName="r" values="6;12;6" dur="2s" repeatCount="indefinite" />
              <animate attributeName="opacity" values="1;0;1" dur="2s" repeatCount="indefinite" />
            </circle>
          </svg>
        </div>
        <div class="cc-grid">
          <div class="cc-stat">
            <div class="cc-stat-val">0.8</div>
            <div class="cc-stat-lbl">Spread</div>
          </div>
          <div class="cc-stat">
            <div class="cc-stat-val">1:500</div>
            <div class="cc-stat-lbl">Leverage</div>
          </div>
          <div class="cc-stat">
            <div class="cc-stat-val">$10</div>
            <div class="cc-stat-lbl">Min</div>
          </div>
          <div class="cc-stat">
            <div class="cc-stat-val">Instant</div>
            <div class="cc-stat-lbl">Execute</div>
          </div>
        </div>
      </div>
      <div class="chip chip-1">
        <div class="chip-ico">📈</div>
        <div class="chip-lbl">Today's P&L</div>
        <div class="chip-val up">+$3,241.80</div>
      </div>
      <div class="chip chip-2">
        <div class="chip-ico">🏆</div>
        <div class="chip-lbl">Win Rate</div>
        <div class="chip-val gold">74.6%</div>
      </div>
    </div>
  </section>

  <!-- ═══════════ FEATURE BAND -->
  <div class="feature-band sr">
    <div class="fb-item">
      <div class="fb-ico-box">⚡</div>
      <div>
        <div class="fb-title">Up to 1:2000 Leverage</div>
        <div class="fb-sub">Maximum market exposure</div>
      </div>
    </div>
    <div class="fb-item">
      <div class="fb-ico-box">💸</div>
      <div>
        <div class="fb-title">Same-Day Withdrawals</div>
        <div class="fb-sub">Instant fund access</div>
      </div>
    </div>
    <div class="fb-item">
      <div class="fb-ico-box">🎁</div>
      <div>
        <div class="fb-title">$500 Welcome Bonus</div>
        <div class="fb-sub">For new accounts</div>
      </div>
    </div>
    <div class="fb-item">
      <div class="fb-ico-box">🌐</div>
      <div>
        <div class="fb-title">24/7 Live Support</div>
        <div class="fb-sub">Always here for you</div>
      </div>
    </div>
  </div>

  <!-- ═══════════ WHY US -->
  <section class="why-us" id="why">
    <div class="why-grid">
      <div class="sr-l">
        <div class="sec-label"><span class="sec-label-text">Why Choose Us</span></div>
        <h2 class="sec-heading">Your Trusted Partner in <span class="sec-hl">Global Forex</span></h2>
        <p class="sec-sub">Every broker on our platform is rigorously vetted, every review independently verified. We
          put your success first — always.</p>
        <div class="why-cards-grid">
          <div class="why-card sr" data-delay="1">
            <div class="wc-ico t">🔒</div>
            <h4>Regulated Brokers Only</h4>
            <p>FCA, CySEC, ASIC oversight. Your capital is always segregated and protected.</p>
          </div>
          <div class="why-card sr" data-delay="2">
            <div class="wc-ico g">📊</div>
            <h4>Expert Daily Analysis</h4>
            <p>Professional signals and market insights delivered every morning before open.</p>
          </div>
          <div class="why-card sr" data-delay="3">
            <div class="wc-ico t">🎓</div>
            <h4>Complete Education</h4>
            <p>From first trade to advanced strategy — our free courses cover everything.</p>
          </div>
          <div class="why-card sr" data-delay="4">
            <div class="wc-ico g">💰</div>
            <h4>IB Commissions</h4>
            <p>Earn up to $15/lot with our industry-leading partnership program.</p>
          </div>
        </div>
      </div>
      <div class="sr-r">
        <div class="perf-card">
          <div class="perf-title">Live Performance Tracker</div>
          <div id="perfContainer"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ STATS -->
  <div class="stats-belt">
    <div class="stat-blk sr" data-delay="1">
      <div class="stat-num" data-target="50000" data-suffix="+">0</div>
      <div class="stat-lbl">Active Traders</div>
    </div>
    <div class="stat-blk sr" data-delay="2">
      <div class="stat-num" data-target="850" data-suffix="M+">0</div>
      <div class="stat-lbl">USD Monthly Volume</div>
    </div>
    <div class="stat-blk sr" data-delay="3">
      <div class="stat-num" data-target="15" data-suffix="+">0</div>
      <div class="stat-lbl">Partner Brokers</div>
    </div>
    <div class="stat-blk sr" data-delay="4">
      <div class="stat-num" data-target="98" data-suffix="%">0</div>
      <div class="stat-lbl">Client Satisfaction</div>
    </div>
  </div>

  <!-- ═══════════ BROKERS -->
  <section class="brokers" id="brokers">
    <div class="brokers-top sr">
      <div>
        <div class="sec-label"><span class="sec-label-text">Broker Reviews</span></div>
        <h2 class="sec-heading">Top Rated <span class="sec-hl">Brokers</span></h2>
        <p class="sec-sub" style="max-width:420px">Hand-picked, independently reviewed, and ranked for your trading
          success.</p>
      </div>
      <div class="broker-filters">
        <div class="bfil on" onclick="setFil(this)">All</div>
        <div class="bfil" onclick="setFil(this)">ECN</div>
        <div class="bfil" onclick="setFil(this)">Standard</div>
        <div class="bfil" onclick="setFil(this)">Crypto</div>
      </div>
    </div>
    <div class="broker-grid" id="brokerGrid"></div>
  </section>

  <!-- ═══════════ MARKET OVERVIEW -->
  <section class="market" id="market">
    <div class="sr">
      <div class="sec-label"><span class="sec-label-text">Live Markets</span></div>
      <h2 class="sec-heading">Market <span class="sec-hl">Overview</span></h2>
      <p class="sec-sub">Real-time quotes, spreads and market sentiment at a glance.</p>
    </div>
    <div class="mkt-layout">
      <div class="mkt-table sr">
        <div class="mkt-head">
          <span>Pair</span><span>Bid</span><span>Ask</span><span>Change</span><span>Spread</span>
        </div>
        <div id="mktRows"></div>
      </div>
      <div class="mkt-side">
        <div class="mkt-side-card sr" data-delay="1">
          <div class="msc-title">Market Sentiment</div>
          <div id="sentRows"></div>
        </div>
        <div class="mkt-side-card sr" data-delay="2">
          <div class="msc-title">Trading Sessions</div>
          <div id="sessRows"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ ARTICLES -->
  <section class="articles" id="articles">
    <div class="art-top sr">
      <div>
        <div class="sec-label"><span class="sec-label-text">Market Insights</span></div>
        <h2 class="sec-heading">Latest <span class="sec-hl">Articles & Guides</span></h2>
      </div>
      <a href="#" class="btn-ghost" style="display:inline-block">View All →</a>
    </div>
    <div class="art-grid" id="artGrid"></div>
  </section>

  <!-- ═══════════ EDUCATION -->
  <section class="education" id="education">
    <div class="sr" style="text-align:center;max-width:580px;margin:0 auto 0">
      <div class="sec-label" style="justify-content:center"><span class="sec-label-text">Free Education</span></div>
      <h2 class="sec-heading">Learn to Trade <span class="sec-hl">Like a Pro</span></h2>
      <p class="sec-sub" style="margin:0 auto">From complete beginner to professional trader — everything you need,
        completely free.</p>
    </div>
    <div class="edu-grid" id="eduGrid"></div>
  </section>

  <!-- ═══════════ TOOLS -->
  <section class="tools" id="tools">
    <div class="sr" style="text-align:center;max-width:560px;margin:0 auto 0">
      <div class="sec-label" style="justify-content:center"><span class="sec-label-text">Trading Tools</span></div>
      <h2 class="sec-heading">Professional <span class="sec-hl">Tools</span> for Every Trader</h2>
    </div>
    <div class="tools-grid" id="toolsGrid"></div>
  </section>

  <!-- ═══════════ PLATFORMS -->
  <section class="platforms" id="platforms">
    <div class="sr" style="text-align:center;max-width:560px;margin:0 auto 0">
      <div class="sec-label" style="justify-content:center"><span class="sec-label-text">Platforms</span></div>
      <h2 class="sec-heading">Trade on <span class="sec-hl">Any Device</span></h2>
      <p class="sec-sub" style="margin:0 auto">Access global markets from desktop, browser, or smartphone — 24 hours a
        day, 5 days a week.</p>
    </div>
    <div class="plat-grid" id="platGrid"></div>
  </section>

  <!-- ═══════════ IB PROGRAM -->
  <section class="ib-program" id="ib">
    <div class="ib-layout">
      <div class="sr-l">
        <div class="sec-label"><span class="sec-label-text">Partnership</span></div>
        <h2 class="sec-heading">Join Our IB Program &amp;<br><span class="sec-hl">Earn Commissions</span></h2>
        <p class="sec-sub">Become an Introducing Broker and build a meaningful passive income stream. Industry-leading
          commissions, real-time reporting, dedicated support.</p>
        <div class="ib-steps">
          <div class="ib-step">
            <div class="ib-num">1</div>
            <div>
              <h4>Register as IB Partner</h4>
              <p>Quick online form — get your unique referral link within minutes.</p>
            </div>
          </div>
          <div class="ib-step">
            <div class="ib-num">2</div>
            <div>
              <h4>Refer Your Network</h4>
              <p>Share via social media, website, WhatsApp, or in person.</p>
            </div>
          </div>
          <div class="ib-step">
            <div class="ib-num">3</div>
            <div>
              <h4>Earn Per Lot Traded</h4>
              <p>Commissions credited instantly on every trade your clients make.</p>
            </div>
          </div>
          <div class="ib-step">
            <div class="ib-num">4</div>
            <div>
              <h4>Withdraw Anytime</h4>
              <p>Same-day withdrawals to bank, JazzCash, Easypaisa, crypto.</p>
            </div>
          </div>
        </div>
      </div>
      <div class="sr-r">
        <div class="ib-panel">
          <div class="ib-panel-title">Commission Structure</div>
          <div class="ib-tier">
            <div>
              <div class="ib-t-name">🥉 Bronze</div>
              <div class="ib-t-clients">1–10 clients</div>
            </div>
            <div class="ib-t-comm">$5<span style="font-size:.85rem;color:var(--mist2)">/lot</span></div>
          </div>
          <div class="ib-tier">
            <div>
              <div class="ib-t-name">🥈 Silver</div>
              <div class="ib-t-clients">11–50 clients</div>
            </div>
            <div class="ib-t-comm">$8<span style="font-size:.85rem;color:var(--mist2)">/lot</span></div>
          </div>
          <div class="ib-tier">
            <div>
              <div class="ib-t-name">🥇 Gold</div>
              <div class="ib-t-clients">51–200 clients</div>
            </div>
            <div class="ib-t-comm">$12<span style="font-size:.85rem;color:var(--mist2)">/lot</span></div>
          </div>
          <div class="ib-tier">
            <div>
              <div class="ib-t-name">💎 Platinum</div>
              <div class="ib-t-clients">200+ clients</div>
            </div>
            <div class="ib-t-comm">$15<span style="font-size:.85rem;color:var(--mist2)">/lot</span></div>
          </div>
          <div class="ib-cta-wrap">
            <button class="btn-hero-main" style="width:100%;justify-content:center">🤝 Become an IB Partner</button>
            <div class="ib-note">No upfront cost · Start earning immediately</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ TESTIMONIALS -->
  <section class="testimonials" id="testimonials">
    <div class="sr" style="text-align:center;max-width:560px;margin:0 auto 36px">
      <div class="sec-label" style="justify-content:center"><span class="sec-label-text">Testimonials</span></div>
      <h2 class="sec-heading">Traders Love <span class="sec-hl">ZEN TRUST CAPITAL</span></h2>
      <p class="sec-sub" style="margin:0 auto">Thousands of Pakistani and global traders trust our platform every day.
      </p>
    </div>
    <div class="test-grid" id="testGrid"></div>
  </section>

  <!-- ═══════════ FAQ -->
  <section class="faq" id="faq">
    <div class="sr" style="text-align:center;max-width:560px;margin:0 auto 36px">
      <div class="sec-label" style="justify-content:center"><span class="sec-label-text">FAQ</span></div>
      <h2 class="sec-heading">Frequently Asked <span class="sec-hl">Questions</span></h2>
    </div>
    <div class="faq-grid" id="faqGrid"></div>
  </section>

  <!-- ═══════════ CTA BANNER -->
  <section class="cta-banner" id="contact">
    <div class="cta-inner sr">
      <div class="sec-label" style="justify-content:center"><span class="sec-label-text">Get Started</span></div>
      <h2>Ready to Start Your<br><span class="sec-hl">Trading Journey?</span></h2>
      <p>Join 50,000+ traders who trust ZEN TRUST CAPITAL. Open a free account in minutes and begin trading with the
        world's best brokers.</p>
      <div class="cta-btns">
        <a href="/open-account" class="btn-hero-main">🚀 Open Free Account <span class="btn-arrow">→</span></a>
        <a href="/contact" class="btn-hero-out">📞 Talk to an Expert <span class="btn-arrow">→</span></a>
      </div>
    </div>
  </section>

  <!-- ═══════════ FOOTER -->
  <%- include('partials/footer') %>
  <script src="/js/script.js"></script>

<script src="/js/theme.js"></script>
<script>
  
  function setFil(el) {
  document.querySelectorAll('.bfil').forEach(e => e.classList.remove('on'));
  el.classList.add('on');
  console.log(el.innerHTML);
  let bkCard = document.querySelectorAll('.bk-card');
  console.log(bkCard.length);

bkCard.forEach(bkCardElement => {

    let chips = bkCardElement.querySelectorAll('.bk-chip');
let chipArray = ["all"];
  // console.log(chips);
chips.forEach(chipsElement => {
  chipArray.push(chipsElement.innerHTML.toLocaleLowerCase());
  console.log(chipArray);

if (chipArray.includes(el.innerHTML.toLocaleLowerCase())) {
    bkCardElement.style.display = "initial";
  }else{
    bkCardElement.style.display = "none";

  }

});


  });

  
  
  
}
</script>

</body>

</html>