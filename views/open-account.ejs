<%- include('partials/head') %>

<link rel="stylesheet" href="/css/styles-pages.css">
<link rel="stylesheet" href="/css/style.css">
<link rel="stylesheet" href="/css/header.css">

<style>
  .open-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    min-height: calc(100vh - 68px);
  }

  .open-left {
    background: linear-gradient(135deg, var(--pages-bg2), var(--pages-bg));
    border-right: 1px solid var(--pages-border);
    padding: 60px 5%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .open-left::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 70% 60% at 80% 50%,
      rgba(201, 168, 76, 0.07) 0%,
      transparent 60%
    );
  }

  .open-right {
    padding: 60px 5%;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .benefit-row {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 0;
    border-bottom: 1px solid var(--pages-border);
  }

  .benefit-row:last-child {
    border-bottom: none;
  }

  .benefit-icon {
    width: 42px;
    height: 42px;
    border-radius: 10px;
        background: var(--pages-card-bg);
    border: 1px solid var(--bk-border);
    
    box-shadow: var(--shadow-card);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    flex-shrink: 0;
  }

  .benefit-text strong {
    display: block;
    font-size: 0.95rem;
    font-weight: 600;
  }

  .benefit-text span {
    font-size: 0.82rem;
    color: var(--pages-text2);
  }

  .steps-indicator {
    display: flex;
    gap: 8px;
    margin-bottom: 28px;
  }

  .step-dot {
    flex: 1;
    height: 4px;
    border-radius: 2px;
    background: var(--pages-bg4);
    transition: background var(--pages-transition);
  }

  .step-dot.active {
    background: var(--darkBlue-to-teal12);
  }

  .step-panel {
    display: none;
  }

  .step-panel.active {
    display: block;
  }

  .privacy-link {
    color: var(--darkBlue-to-teal12);
  }

  nav.main,
  .btn-cta {
    display: none;
  }

  #btt,
  footer,
  .risk-note {
    display: none;
  }

  .privacy-text {
    text-align: center;
    font-size: 0.76rem;
    color: var(--pages-text3);
    margin-top: 20px;
  }

  /* Removed inline styles */

  .page-wrapper-top {
    padding-top: 68px;
  }

  .open-left-inner {
    position: relative;
    z-index: 1;
  }

  .free-join-label {
    margin-bottom: 20px;
  }

  .open-left-heading {
    margin-bottom: 8px;
  }

  .open-left-description {
    margin-bottom: 32px;
  }

  .open-form-container {
    max-width: 420px;
    width: 100%;
    margin: 0 auto;
  }

  .open-form-heading {
    margin-bottom: 6px;
  }

  .open-form-description {
    margin-bottom: 28px;
    font-size: 0.9rem;
  }

  .step-title {
    font-family: var(--pages-font-display);
    font-size: 0.82rem;
    color: var(--pages-text3);
    margin-bottom: 20px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .btn-center {
    justify-content: center;
  }

  .swap-account-box {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 20px;
        background: var(--pages-card-bg);
    border: 1px solid var(--bk-border);
    transition: all .32s;
    box-shadow: var(--shadow-card);
    border-radius: 10px;
    padding: 12px;
  }

  .gold-checkbox {
    accent-color: var(--darkBlue-to-teal12);
  }

  .swap-account-label {
    font-size: 0.88rem;
    color: var(--pages-text);
  }

  .step-actions {
    display: flex;
    gap: 10px;
  }

  .step-btn-back {
    flex: 1;
    justify-content: center;
  }

  .step-btn-next {
    flex: 2;
    justify-content: center;
  }

  .summary-card {
    /* background: var(--pages-gold-dim);
    border-color: rgba(201, 168, 76, 0.3); */
    margin-bottom: 20px;
  }

  .summary-title {
    font-family: var(--pages-font-display);
    font-weight: 700;
    margin-bottom: 12px;
  }

  .summary-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .summary-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.88rem;
  }

  .agreement-box {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    margin-bottom: 20px;
  }

  .agreement-checkbox {
    accent-color: var(--darkBlue-to-teal12);
    margin-top: 3px;
  }

  .agreement-label {
    font-size: 0.82rem;
    color: var(--pages-text2);
  }

  .ssl-note {
    text-align: center;
    font-size: 0.76rem;
    color: var(--pages-text3);
    margin-top: 20px;
  }

  @media (max-width: 900px) {
    .open-layout {
      grid-template-columns: 1fr;
    }

    .open-left {
      display: none;
    }
  }
</style>
</head>

<body>
  <%- include('partials/header') %>

  <div class="page-wrapper page-wrapper-top">
    <div class="open-layout">

      <!-- Left -->
      <div class="open-left">
        <div class="open-left-inner">
  <span class="section-label"><div class="ld">✦</div>
        Free to Join</span>
          <h2 class="open-left-heading">
            Start Trading in <span class="text-gold">Minutes</span>
          </h2>

          <p class="text-muted open-left-description">
            Join 50,000+ traders who chose ZEN TRUST CAPITAL as their trusted partner.
          </p>

          <div>
            <div class="benefit-row">
              <div class="benefit-icon">⚡</div>
              <div class="benefit-text">
                <strong>Up to 1:2000 Leverage</strong>
                <span>Maximum market exposure with controlled risk</span>
              </div>
            </div>

            <div class="benefit-row">
              <div class="benefit-icon">💸</div>
              <div class="benefit-text">
                <strong>Same-Day Withdrawals</strong>
                <span>JazzCash, Easypaisa, bank transfer, crypto</span>
              </div>
            </div>

            <div class="benefit-row">
              <div class="benefit-icon">🎁</div>
              <div class="benefit-text">
                <strong>$500 Welcome Bonus</strong>
                <span>Available for eligible new accounts</span>
              </div>
            </div>

            <div class="benefit-row">
              <div class="benefit-icon">🛡️</div>
              <div class="benefit-text">
                <strong>FCA Regulated Brokers</strong>
                <span>Your funds are always segregated</span>
              </div>
            </div>

            <div class="benefit-row">
              <div class="benefit-icon">🌐</div>
              <div class="benefit-text">
                <strong>24/7 Urdu Support</strong>
                <span>Real humans, not bots</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right -->
      <div class="open-right">
        <div class="open-form-container">

          <h2 class="open-form-heading">Open Free Account</h2>

          <p class="text-muted open-form-description">
            Takes less than 2 minutes. No documents needed to start.
          </p>

          <div class="steps-indicator">
            <div class="step-dot active" id="dot-1"></div>
            <div class="step-dot" id="dot-2"></div>
            <div class="step-dot" id="dot-3"></div>
          </div>

          <!-- Step 1 -->
          <div class="step-panel active" id="step-1">
            <div class="step-title">Step 1 — Personal Info</div>

            <div class="form-group">
              <label class="form-label">Full Name</label>
              <input type="text" class="form-input" placeholder="As on CNIC / Passport">
            </div>

            <div class="form-group">
              <label class="form-label">Email Address</label>
              <input type="email" class="form-input" placeholder="you@example.com">
            </div>

            <div class="form-group">
              <label class="form-label">Phone / WhatsApp</label>
              <input type="text" class="form-input" placeholder="+92 300 0000000">
            </div>

            <div class="form-group">
              <label class="form-label">Country</label>
              <select class="form-input">
                <option selected>Pakistan</option>
                <option>United Arab Emirates</option>
                <option>United Kingdom</option>
                <option>Other</option>
              </select>
            </div>

            <button class="btn-primary w-full btn-center" onclick="nextStep(2)">
              Continue →
            </button>
          </div>

          <!-- Step 2 -->
          <div class="step-panel" id="step-2">
            <div class="step-title">Step 2 — Account Setup</div>

            <div class="form-group">
              <label class="form-label">Choose Broker</label>
              <select class="form-input">
                <option>Exness (Recommended ⭐)</option>
                <option>XM Global</option>
                <option>IC Markets</option>
                <option>FP Markets</option>
              </select>
            </div>

            <div class="form-group">
              <label class="form-label">Account Type</label>
              <select class="form-input">
                <option>Standard (No Commission)</option>
                <option>Pro (Raw Spreads)</option>
                <option>Cent Account (Micro Lots)</option>
              </select>
            </div>

            <div class="form-group">
              <label class="form-label">Account Currency</label>
              <select class="form-input">
                <option>USD</option>
                <option>EUR</option>
                <option>GBP</option>
              </select>
            </div>

            <div class="swap-account-box">
              <input type="checkbox" id="islamic" class="gold-checkbox">
              <label for="islamic" class="swap-account-label">
                🕌 Enable Islamic (Swap-Free) Account
              </label>
            </div>

            <div class="step-actions">
              <button class="btn-secondary step-btn-back" onclick="nextStep(1)">
                ← Back
              </button>

              <button class="btn-primary step-btn-next" onclick="nextStep(3)">
                Continue →
              </button>
            </div>
          </div>

          <!-- Step 3 -->
          <div class="step-panel" id="step-3">
            <div class="step-title">Step 3 — Confirm</div>

            <div class="card summary-card">
              <div class="summary-title">Account Summary</div>

              <div class="summary-list">
                <div class="summary-row">
                  <span class="text-muted">Broker</span>
                  <strong>Exness</strong>
                </div>

                <div class="summary-row">
                  <span class="text-muted">Account Type</span>
                  <strong>Standard</strong>
                </div>

                <div class="summary-row">
                  <span class="text-muted">Currency</span>
                  <strong>USD</strong>
                </div>

                <div class="summary-row">
                  <span class="text-muted">Islamic</span>
                  <strong class="text-green">Yes</strong>
                </div>
              </div>
            </div>

            <div class="agreement-box">
              <input type="checkbox" id="agree" class="agreement-checkbox">

              <label for="agree" class="agreement-label">
                I agree to the
                <a href="terms.html" class="text-gold">Terms of Service</a>
                and
                <a href="privacy.html" class="text-gold">Privacy Policy</a>.
                I understand trading involves risk.
              </label>
            </div>

            <div class="step-actions">
              <button class="btn-secondary step-btn-back" onclick="nextStep(2)">
                ← Back
              </button>

              <button class="btn-primary step-btn-next" onclick="submitAccount()">
                🚀 Create Account
              </button>
            </div>
          </div>

          <p class="ssl-note">
            🔒 256-bit SSL encryption · No spam · Unsubscribe anytime
          </p>

        </div>
      </div>

    </div>
  </div>

  <%- include('partials/footer') %>

  <script src="/js/theme.js"></script>
  <script src="/js/script.js"></script>

  <script>
    function nextStep(n) {
      document.querySelectorAll('.step-panel').forEach(p => p.classList.remove('active'));
      document.querySelectorAll('.step-dot').forEach(d => d.classList.remove('active'));
      document.getElementById('step-' + n).classList.add('active');
      for (let i = 1; i <= n; i++) {
        document.getElementById('dot-' + i).classList.add('active');
      }
    }

    function submitAccount() {
      alert('🎉 Account created successfully! Check your email for login credentials.');
    }
  </script>
</body>
</html>